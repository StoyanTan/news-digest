{
  "name": "daily-news-digest",
  "version": "1.0.0",
  "description": "Daily news digest generator powered by Claude AI",
  "main": "digest.ts",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "npx tsx server.ts",
    "test": "npx tsx digest.ts --smoke",
    "setup": "npx tsx setup.ts",
    "build": "tsc --noEmit",
    "preserve": "npx --yes kill-port 3000",
    "serve": "npx tsx server.ts",
    "test:discord": "npx tsx test/discord-ping.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "express": "latest",
    "nodemailer": "latest"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
